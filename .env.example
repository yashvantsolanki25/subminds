# SubMinds Desktop Application Configuration
# Copy this file to .env and fill in your credentials

# IBM WatsonX Credentials (Required for AI Analysis)
# Get these from: https://cloud.ibm.com/
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here
IBM_SPACE_ID=your_watsonx_space_id_here
IBM_WATSON_URL=https://us-south.ml.cloud.ibm.com

# Camera Configuration
# Camera ID (0 for default webcam, 1 for external camera, etc.)
CAMERA_ID=0

# Analysis Settings
# Time interval between analyses in seconds
ANALYSIS_INTERVAL=2.0

# Model Configuration
MODEL_ID=meta-llama/llama-4-maverick-17b-128e-instruct-fp8
TEMPERATURE=0.7
TOP_P=0.9
MAX_TOKENS=2000

# Optional: Logging Level
LOG_LEVEL=INFO