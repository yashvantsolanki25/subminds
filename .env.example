# SubMinds Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# IBM Cloud Credentials
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here

# Database Credentials - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=subminds
POSTGRES_USER=subminds_user
POSTGRES_PASSWORD=your_secure_password_here

# Database Credentials - MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=subminds
MONGO_USER=subminds_user
MONGO_PASSWORD=your_secure_password_here

# Database Credentials - Redis (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Application Settings
DEBUG=True
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_for_sessions

# TORCS Settings
TORCS_HOST=localhost
TORCS_PORT=3101
TORCS_VISION_PORT=3102

# Camera Settings
CAMERA_ID=0
CAMERA_FPS=30

# File Storage
DATA_DIR=./data
MODELS_DIR=./data/models
ART_SAMPLES_DIR=./data/art_samples