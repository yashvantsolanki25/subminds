# SubMinds Desktop Application Configuration
# Copy this file to .env and fill in your credentials

# IBM Cloud Credentials (Required for AI Analysis)
# Get these from: https://cloud.ibm.com/
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here

# Camera Configuration
# Camera ID (0 for default webcam, 1 for external camera, etc.)
CAMERA_ID=0

# Analysis Settings
# Time interval between analyses in seconds
ANALYSIS_INTERVAL=2.0

# Optional: Logging Level
LOG_LEVEL=INFO

# Made with Bob - Desktop Edition